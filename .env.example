# =============================================================================
# Redbud Travel Planner — Environment Configuration
# Copy this file to .env and set values for your environment.
# All instances (development, production, etc.) use only this file.
# =============================================================================

# Environment name — controls DB naming, cookie security, log verbosity
# Values: development | production
NODE_ENV=development

# =============================================================================
# Ports
# =============================================================================
# The port Express listens on inside the container
PORT=3002

# The host port the app is exposed on (what you type in the browser)
APP_PORT=3510

# Host port for the database (avoids conflicts with other postgres instances)
DB_PORT=5442

# Host port for Redis
REDIS_PORT=6389

# =============================================================================
# Auth service
# =============================================================================
# RS256 public key — used to verify JWTs issued by the auth service
# Get this from the auth service (corresponds to its JWT_PRIVATE_KEY)
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Frontend auth service URL and app identifier (used by Vite/frontend)
VITE_AUTH_URL=https://auth.example.com
VITE_APP_SLUG=your-app-slug


# =============================================================================
# Database
# =============================================================================
# Inside docker-compose, DB_HOST must match the postgres service name
DB_HOST=postgres
DB_NAME=travel_planner
DB_USER=postgres
DB_PASSWORD=postgres

# =============================================================================
# Redis
# =============================================================================
# Inside docker-compose, REDIS_HOST must match the redis service name
REDIS_HOST=redis
# Set to true to enable Redis for session storage (recommended for production)
REDIS_ENABLED=false

# =============================================================================
# Logging
# =============================================================================
# Values: error | warn | info | debug
LOG_LEVEL=debug
